{
  "name": "sergeant-reviewer",
  "displayName": "Sergeant",
  "description": "Sergeant open-source engineering reviewer for VS Code.",
  "version": "0.4.0",
  "publisher": "thetechguyds",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jaydumisuni/Sergeant.git"
  },
  "icon": "resources/srg-logo-and-icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./src/vscode/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sergeant",
          "title": "Sergeant",
          "icon": "resources/sergeant-activity.svg"
        }
      ]
    },
    "views": {
      "sergeant": [
        {
          "id": "sergeant.actions",
          "name": "Command Center"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "sergeant.actions",
        "contents": "Open the Sergeant Command Center to review, verify, and inspect this workspace."
      }
    ],
    "commands": [
      {
        "command": "sergeant.openCommandCenter",
        "title": "Sergeant: Open Full Command Center"
      },
      {
        "command": "sergeant.reviewWorkspace",
        "title": "Sergeant: Review Workspace"
      },
      {
        "command": "sergeant.appReviewWorkspace",
        "title": "Sergeant: App Bridge Review"
      },
      {
        "command": "sergeant.reviewCurrentFile",
        "title": "Sergeant: Review Current File"
      },
      {
        "command": "sergeant.reviewChangedFiles",
        "title": "Sergeant: Review Changed Files"
      },
      {
        "command": "sergeant.v2Mission",
        "title": "Sergeant: Build V2 Mission"
      },
      {
        "command": "sergeant.proofSuite",
        "title": "Sergeant: Run Proof Suite"
      },
      {
        "command": "sergeant.finalProof",
        "title": "Sergeant: Run Final Proof"
      },
      {
        "command": "sergeant.verifyStandard",
        "title": "Sergeant: Verify Standard"
      },
      {
        "command": "sergeant.battleTests",
        "title": "Sergeant: Validate Battle Tests"
      },
      {
        "command": "sergeant.ideBenchContract",
        "title": "Sergeant: IDE Bench Contract"
      },
      {
        "command": "sergeant.openLastReport",
        "title": "Sergeant: Open Last Report"
      },
      {
        "command": "sergeant.copyLastReport",
        "title": "Sergeant: Copy Last Report"
      },
      {
        "command": "sergeant.exportLastReport",
        "title": "Sergeant: Export Last Report"
      }
    ],
    "configuration": {
      "title": "Sergeant",
      "properties": {
        "sergeant.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "Python executable used to run Sergeant."
        },
        "sergeant.provider": {
          "type": "string",
          "default": "Automatic Open-Source Review",
          "enum": [
            "Automatic Open-Source Review",
            "Free Claude Code (FCC)",
            "Ollama",
            "LM Studio",
            "OpenAI-compatible Endpoint",
            "Disabled"
          ],
          "description": "Legacy display preference retained for compatibility. New routing uses the llmProvider setting."
        },
        "sergeant.llmPolicy": {
          "type": "string",
          "default": "preferred",
          "enum": [
            "preferred",
            "required",
            "disabled"
          ],
          "enumDescriptions": [
            "Use semantic LLM review by default and fall back to deterministic Sergeant evidence when no route is available.",
            "Require semantic LLM review before Sergeant can approve.",
            "Disable semantic LLM review."
          ],
          "description": "Semantic-review gate policy."
        },
        "sergeant.llmProvider": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "fcc",
            "ollama",
            "lm-studio",
            "openai-compatible",
            "disabled"
          ],
          "enumDescriptions": [
            "Discover FCC, Ollama, or LM Studio on loopback and prefer the strongest discovered open model.",
            "Use Free Claude Code at its configured local port.",
            "Use Ollama's OpenAI-compatible endpoint.",
            "Use LM Studio's OpenAI-compatible endpoint.",
            "Use the explicitly configured llmBaseUrl.",
            "Disable semantic review."
          ],
          "description": "Semantic-review provider route."
        },
        "sergeant.llmBaseUrl": {
          "type": "string",
          "default": "",
          "description": "Explicit OpenAI-compatible endpoint. Remote endpoints are never auto-discovered; API credentials remain in SERGEANT_LLM_API_KEY."
        },
        "sergeant.llmModel": {
          "type": "string",
          "default": "",
          "description": "Optional provider model slug. Blank uses Sergeant's open-model preference: GLM-5.2, Qwen3-Coder-Next, Kimi K2.5, then provider fallback."
        },
        "sergeant.llmProtocol": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "responses",
            "chat_completions"
          ],
          "description": "Wire protocol. FCC uses OpenAI Responses; most generic providers use Chat Completions."
        },
        "sergeant.llmCouncil": {
          "type": "string",
          "default": "adaptive",
          "enum": [
            "adaptive",
            "always",
            "single"
          ],
          "description": "Adaptive uses a second discovered open model for high-risk or disputed changes."
        }
      }
    }
  }
}
